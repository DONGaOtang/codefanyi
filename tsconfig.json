{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["adapters/**/*.ts", "privacy/**/*.ts", "plain-language/**/*.ts", "server/**/*.ts", "cli/**/*.ts", "scripts/**/*.ts", "tests/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
